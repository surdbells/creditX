{
    "name": "dost/creditx",
    "description": "CreditX v2.0 Loan Management System API",
    "type": "project",
    "license": "proprietary",
    "authors": [
        {
            "name": "CreditX Claude",
            "email": "claude@kodek.ng"
        }
    ],
    "minimum-stability": "stable",
    "require": {
        "slim/slim": "^4.0",
        "slim/psr7": "^1.0",
        "php-di/php-di": "^7.0",
        "php-di/slim-bridge": "^3.0",
        "doctrine/orm": "^3.0",
        "doctrine/dbal": "^4.0",
        "doctrine/migrations": "^3.0",
        "firebase/php-jwt": "^6.0",
        "symfony/validator": "^7.0",
        "symfony/messenger": "^7.0",
        "predis/predis": "^2.0",
        "vlucas/phpdotenv": "^5.0",
        "monolog/monolog": "^3.0",
        "zircote/swagger-php": "^4.0",
        "league/flysystem": "^3.0",
        "dompdf/dompdf": "^3.0",
        "ramsey/uuid": "^4.0",
        "symfony/cache": "^7.0",
        "symfony/console": "^7.0",
        "symfony/property-access": "^7.0",
        "ramsey/uuid-doctrine": "^2.0"
    },
    "config": {
        "audit": {
            "block-insecure": false
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/",
            "App\\Database\\Migrations\\": "database/migrations/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "seed": "php bin/seed.php",
        "serve": "php -S localhost:8080 -t public"
    }
}
