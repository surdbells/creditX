# ─── Application ───
APP_NAME=CreditX
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_TIMEZONE=Africa/Lagos

# ─── Database ───
DB_DRIVER=pdo_pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=creditx
DB_USER=creditx_user
DB_PASSWORD=secret
DB_CHARSET=utf8

# ─── JWT ───
JWT_SECRET=your-256-bit-secret-key-change-in-production
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800
JWT_ISSUER=creditx-api
JWT_ALGORITHM=HS256

# ─── Redis ───
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_PREFIX=creditx:

# ─── Mail (ZeptoMail) ───
MAIL_DRIVER=zeptomail
ZEPTOMAIL_API_KEY=
ZEPTOMAIL_FROM_EMAIL=noreply@creditx.com
ZEPTOMAIL_FROM_NAME=CreditX

# ─── SMS (Termii) ───
TERMII_API_KEY=
TERMII_SENDER_ID=CreditX

# ─── Payments (Paystack) ───
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_WEBHOOK_SECRET=

# ─── File Storage ───
STORAGE_DRIVER=local
STORAGE_PATH=storage/uploads
STORAGE_MAX_SIZE=10485760

# ─── CORS ───
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:8100
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With

# ─── Rate Limiting ───
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW=60

# ─── Logging ───
LOG_CHANNEL=daily
LOG_LEVEL=debug
LOG_PATH=var/log/app.log
